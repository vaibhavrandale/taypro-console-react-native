{
  "expo": {
    "name": "Nectyr",
    "slug": "nectyr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/favicon.png",
    "scheme": "tayproconsole",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.taypro.console",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": true,
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "package": "in.taypro.console",
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon.png",
        "backgroundColor": "#0B0B0F"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ],
      "statusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#1A2547"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/favicon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0B0B0F"
        }
      ],
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Nectyr to access your camera to capture profile photos and attendance."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Nectyr to use your location to verify you are at the site for punch in/out.",
          "locationAlwaysAndWhenInUsePermission": "Allow Nectyr to use your location all the time so attendance works correctly while you are punched in, even if you switch apps.",
          "locationAlwaysPermission": "Allow Nectyr to use your location all the time so attendance works correctly while you are punched in, even if you switch apps.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-task-manager",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "4ac8042a-cb26-475c-9295-4888b4848895"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4ac8042a-cb26-475c-9295-4888b4848895"
    }
  }
}
