{
  "expo": {
    "name": "Taypro Console",
    "slug": "taypro-console-react-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/favicon.png",
    "scheme": "tayproconsole",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.taypro.console"
    },
    "android": {
      "package": "in.taypro.console",
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon.png",
        "backgroundColor": "#0B0B0F"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/favicon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0B0B0F"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "4ac8042a-cb26-475c-9295-4888b4848895"
      }
    }
  }
}
